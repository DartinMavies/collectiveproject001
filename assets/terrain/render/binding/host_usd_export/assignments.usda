#usda 1.0
(
    endTimeCode = 1224
    framesPerSecond = 24
    metersPerUnit = 0.01
    startTimeCode = 1224
    timeCodesPerSecond = 24
    upAxis = "Y"
)

over "main"
{
    over "proxy"
    {
        over "geo"
        {
            over "terrain" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                rel material:binding = </main/proxy/mtl/terrain_mtl>
            }
        }
    }
}

